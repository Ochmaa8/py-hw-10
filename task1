# Создаем пустой словарь
pets = {}

# Запрашиваем информацию у пользователя
name = input("Введите имя питомца: ")
animal_type = input("Введите вид питомца: ")
age = int(input("Введите возраст питомца: "))
owner = input("Введите имя владельца: ")

# Заполняем словарь
pets[name] = {
    "Вид питомца": animal_type,
    "Возраст питомца": age,
    "Имя владельца": owner
}

# Определяем правильное склонение слова "год"
def get_age_string(age):
    if age % 10 == 1 and age % 100 != 11:
        return f"{age} год"
    elif age % 10 in [2, 3, 4] and age % 100 not in [12, 13, 14]:
        return f"{age} года"
    else:
        return f"{age} лет"

# Получаем информацию о питомце ИСПОЛЬЗУЯ keys() И values()
for pet_name, pet_info in pets.items():
    # Получаем ключи и значения
    keys_list = list(pet_info.keys())    # ['Вид питомца', 'Возраст питомца', 'Имя владельца']
    values_list = list(pet_info.values()) # [animal_type, age, owner]
    
    # Извлекаем данные по индексам
    animal_type = values_list[0]
    age_value = values_list[1]
    owner_name = values_list[2]
    
    # Формируем и выводим строку
    age_str = get_age_string(age_value)
    print(f'Это {animal_type} по кличке "{pet_name}". Возраст питомца: {age_str}. Имя владельца: {owner_name}')
